---
import Header from "../components/Header.astro"
import "/src/styles/global.css"
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => {
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});
---
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Matt Labrecque's Blog</title>
</head>
<body> <Header/>
  <p>The rants and musings of a Mathematician and Computer Scientist from Northern New England. New posts every week.</p>
    
    <section>
    <h2>Recent Posts</h2>
  <ul>
  {sortedPosts.map((post) => (
    <li>
      <a href={`${import.meta.env.BASE_URL}posts/${post.id}/`}>{post.data.title}</a>
    </li>
  ))}
  </ul>
  </section>
</body>

<style>
.header{text-align: center;}

</style>
