---
import Header from "../components/Header.astro"
import Project from "../components/Project.astro"
import "../styles/global.css"
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>STOP CONSUMING. START CREATING.</title>
</head>
  <body>
    <Header/>

    <div class="profile-text">

      <p>I'm a third-year Applied Mathematics student at the University of New Hampshire, concentrating in Computational Mathematics and Machine Learning.
        I'm also a film maker, musician, poet, and tinkerer. In short, I'm a creative nerd who uses technology to create and build things that interest 
        me. When I'm not working on my homelab, studying for exams, or DJing, you can usually find me lifting or outdoors enjoying this 
        beautiful planet that we get to call home.
      </p>
    <p>Contact: <span id="copy-email" class="clickable-email">mlabrecque2002 [at] gmail (dot) com</span></p>

    </div>

    <hr class="solid">

    <div>

    <h2>Projects</h2>
      <div class="project-grid">
      
        <Project
          title="Billboard Top-40 Lookup"
        description="I DJ for fun at my college radio station (91.3FM WUNH) and our specialty is we only play music which has not charted in the Top 40 on the 
        Billboard Hot 100 charts. However there wasn't any easy way to determine if a song had charted or not. I solved this by writing a small Python program 
        which automates the retrieval of Billboard data and allows someone to querry it for artist and song data."
        tags={["Python", "Data Processing", "Data Analytics"]}
        />
      
        <Project
          title="Julia to MATLAB Cross-Compiler"
        description="A source-to-source compiler written in Python that translates Julia code into functionally equivalent MATLAB scripts. This project is ongoing as a final
        project under the guidance of Professor Melanie Vinning, this project originally started out as a joke due to both of us disliking MATLAB but turned
        into a full on project where I learned language design, parsing, and the challenges of cross-language translation."
          tags={["Python", "Julia", "MATLAB", "Compiler Design", "AST", "Lexing", "Transpilation"]}
        />

      <Project
        title="Computer-Controlled Telescope"
        description="I decided to put my design, engineering, and programming skills to the test by working on building a computer controlled telescope from scratch. The 
        base of the project is using a custom gear assembly controlled by an Arduino microcontroller to adjust the telescope's position. The telescope also automatically
        accounts for the Earth's rotation as well as the latitude/longitude during positioning. Updates will be posted on YouTube."
        tags={["Robotics", "Python", "C++", "Data Processing", "Arduino", "Design/Prototyping"]}
      />
      <Project
        title="pim - Pi IMproved"
          description="A very simple Python wrapper script for Mario Zechner's agentic coding harness, PiDev. The biggest issue with Pi is the lack of security sandboxing,
          as it allows full filesystem access as well as sudo privielges to the agent which can cause complete chaos if not configured properly. This Python script works along
          with seccomp and bwrap to properly sandbox Pi from having write access outside the current directory, while also preventing it from seeing SSH keys and other secrets."
        tags={["Python", "LLMs"]}
        />
    </div>
    
    <hr class="solid">

    <h2>Education</h2>
    <ul>
      <li>The University of New Hampshire - Durham, NH (2025-Present)</li>
      <ul>
        <li>B.S. in Applied Mathematics, Concentration in Computations</li>
        <li>Member, Hamel Honors and Scholars College</li>
      </ul>
      <li>Nashua Community College - Nashua, NH (2023-2025)</li>
      <ul>
        <li>A.S. in Computer Science</li>
    <li>Member, Phi Theta Kappa Honor Society</li>
        <li>Graduated Summa Cum Laude</li>
      </ul>
    </ul>
  
    <script>
    const emailSpan = document.getElementById('copy-email');
    const originalText = emailSpan.textContent;
    emailSpan.addEventListener('click', async () => {
        try {
            await navigator.clipboard.writeText('mlabrecque2002@gmail.com');
            emailSpan.textContent = 'Copied!';
            setTimeout(() => {
                emailSpan.textContent = originalText;
            }, 1500);
        } catch (err) {
            console.error('Failed to copy:', err);
        }
    });
  </script>
</body>

<style>
  
  .profile-text {
    flex: 1;
    vertical-align: middle;
  }
  
  .project-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
  }
  
  .clickable-email {
    color: #88af6c;
    cursor: pointer;
    text-decoration: underline;
  }
  
  .clickable-email:hover {
    color: #E5C07B;
  }

</style>
