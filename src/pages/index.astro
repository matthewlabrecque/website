    <script>
    const emailSpan = document.getElementById('copy-email');
    const originalText = emailSpan.textContent;
    emailSpan.addEventListener('click', async () => {
        try {
            await navigator.clipboard.writeText('mail@mlabrecque.dev');
            emailSpan.textContent = 'Copied!';
            setTimeout(() => {
                emailSpan.textContent = originalText;
            }, 1500);
        } catch (err) {
            console.error('Failed to copy:', err);
        }
    });
  </script>
