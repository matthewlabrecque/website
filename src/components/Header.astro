<html>
  <head>
    <script src="https://kit.fontawesome.com/1f927a0858.js" crossorigin="anonymous"></script>
  </head>

  <div class="split-header">
      <a class="link" href=" https://ring.liampas.ca/left">&#8592; Left</a>
      <a class="link" href=" https://ring.liampas.ca/right">Right &#8594;</a>
  </div>

<h1 class="split-header">
  <span id="name">MATT LABRECQUE</span>
  <span id="links">
    <a class="link" href="/">Home</a>
    <a class="link" href="/poetry/">Poetry</a>
    <a class="link" href="/blog/">Blog</a>
    
      <span id="socials">
    <!-- This should be placed in it's own container -->
      <a href="https://www.youtube.com/@mttylbrq" aria-label="YouTube">
      <i class="fa-brands fa-youtube"></i>
      <span class="sr-only">YouTube</span>
    </a>
    <a href="https://www.x.com/matthewlabrecque" aria-label="X">
      <i class="fa-brands fa-x-twitter"></i>
        <span class="sr-only">X</span>
      </a>
    <a href="https://github.com/matthewlabrecque" aria-label="GitHub">
