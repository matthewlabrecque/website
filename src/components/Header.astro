<style>
.split-header {

    display: flex;
    justify-content: space-between;
    align-items: center;
    vertical-align: middle;
    width: 100%;
}
#name {
    text-align: center;
    letter-spacing: 7px;
  }
#links {
  vertical-align: middle;
}

#socials {
  all: unset;
  display: inline-flex;
  gap: 0.4rem;
}

#socials a {
  display: inline-flex;
  align-items: center;
  text-decoration: none;
}

.link {
    color: #88af6c;
    cursor: pointer;
    text-decoration: underline;
  }

.link:hover {
  color: #E5C07B;
}

.sr-only {
  position: absolute;
  width: 1px; height: 1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
}

</style>
