    <script>
    const emailSpan = document.getElementById('copy-email');
    const originalText = emailSpan.textContent;
    emailSpan.addEventListener('click', async () => {
        try {
            await navigator.clipboard.writeText('mlabrecque2002@gmail.com');
            emailSpan.textContent = 'Copied!';
            setTimeout(() => {
                emailSpan.textContent = originalText;
            }, 1500);
        } catch (err) {
            console.error('Failed to copy:', err);
        }
    });
  </script>
</body>

<style>
  
  .profile-text {
    flex: 1;
    vertical-align: middle;
  }
  
  .project-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-around;
  }
  
  .clickable-email {
    color: #88af6c;
    cursor: pointer;
    text-decoration: underline;
  }
  
  .clickable-email:hover {
    color: #E5C07B;
  }

</style>
